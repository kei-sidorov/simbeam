# /etc/simcast/demo.env — configuration for simcastd-demo.service.
# Copy to the server, adjust, chmod 0600.

# Fixed pairing secret: keeps the printed pairing URL valid across restarts.
# Generate with: openssl rand -base64 24
SIMCAST_PAIR_SECRET=change-me

# Args for `simcastd demo` (word-split by systemd; avoid values with spaces).
# --chrome-no-sandbox is NOT set: the unit runs as an unprivileged user, and the
# distro chromium ships with the sandbox properly wired. State lives under
# /var/lib/simcast (StateDirectory).
SIMCAST_DEMO_ARGS=--signal wss://simcast.example.com/ws --url https://example.com --name simcast-demo --identity /var/lib/simcast/demo-identity.key --clients /var/lib/simcast/demo-clients.json
