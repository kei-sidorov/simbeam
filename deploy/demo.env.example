# /etc/simbeam/demo.env — configuration for simbeamd-demo.service.
# Copy to the server, adjust, chmod 0600.

# Fixed pairing secret: keeps the printed pairing URL valid across restarts.
# Generate with: openssl rand -base64 24
SIMCAST_PAIR_SECRET=change-me

# Args for `simbeamd demo` (word-split by systemd; avoid values with spaces).
# --chrome-no-sandbox is NOT set: the unit runs as an unprivileged user, and the
# distro chromium ships with the sandbox properly wired. State lives under
# /var/lib/simbeam (StateDirectory).
#
# --signal      the broker WS URL (signal.simbeam.dev fronts the broker on :9000).
# --url         the page the demo device renders (set to wherever the demo page is hosted).
# --client-url  base for the printed pairing link, so clients open the hosted web
#               client (app.simbeam.dev) instead of localhost.
SIMCAST_DEMO_ARGS=--signal wss://signal.simbeam.dev/ws --url https://example.com --client-url https://app.simbeam.dev/ --name simbeam-demo --identity /var/lib/simbeam/demo-identity.key --clients /var/lib/simbeam/demo-clients.json
